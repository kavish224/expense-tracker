# Primary database connection string used by the app and init script.
DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# Optional fallback if you prefer providing POSTGRES_URL instead of DATABASE_URL.
# POSTGRES_URL=postgresql://username:password@host/database?sslmode=require

# JWT signing secret for auth cookies.
# Required in production. Use a long random string, ideally 32+ characters.
SESSION_SECRET=replace-with-a-long-random-secret
